# Environment (local dev)
VITE_APP_ENV=development

# Supabase (CI-safe defaults — override with .env.local for real project)
# Local fallback: the Supabase client uses this when no .env.local is present
VITE_SUPABASE_URL=http://localhost:54321
VITE_SUPABASE_ANON_KEY=placeholder-for-CI

# Sentry (optional)
VITE_SENTRY_DSN=

# PostHog (optional)
VITE_POSTHOG_API_KEY=
VITE_POSTHOG_HOST=

# Phase 2: Edge Function approval (set to "true" to enable)
# When enabled, application approval uses a secure Edge Function instead of browser-side provisioning
VITE_ENABLE_EDGE_APPROVAL=true

# Phase 3: Transactional provisioning (set to "true" to enable)
# When enabled, provisioning uses state machine with idempotency, compensating actions, and retry.
# VITE_ENABLE_EDGE_APPROVAL must also be "true" for this to take effect.
VITE_ENABLE_TRANSACTIONAL_PROVISIONING=false
