{
  "docId": "QA-NOT-009",
  "title": "Notification Testing Specification",
  "totalTests": 65,
  "architecture": {
    "dbTable": "public.notifications",
    "badgeTable": "public.user_badge_counts",
    "preferencesTable": "public.notification_preferences",
    "realtimeEngine": "Supabase Realtime",
    "channelPattern": "notifications:{user_id}"
  },
  "notificationTypes": [
    {"key": "application.created", "display": "Application", "trigger": "New application submitted", "source": "Visitor", "target": "Mentor"},
    {"key": "application.approved", "display": "Application", "trigger": "Application approved", "source": "Mentor", "target": "Student"},
    {"key": "goal.assigned", "display": "Goal", "trigger": "Goal assigned", "source": "Mentor", "target": "Student"},
    {"key": "goal.completed", "display": "Goal", "trigger": "Goal completed", "source": "Student", "target": "Mentor"},
    {"key": "task.assigned", "display": "Task", "trigger": "Task assigned", "source": "Mentor", "target": "Student"},
    {"key": "task.submitted", "display": "Task", "trigger": "Task submitted", "source": "Student", "target": "Mentor"},
    {"key": "task.approved", "display": "Task", "trigger": "Task approved", "source": "Mentor", "target": "Student"},
    {"key": "session.booked", "display": "Session", "trigger": "Session booked", "source": "Student", "target": "Mentor"},
    {"key": "session.rescheduled", "display": "Session", "trigger": "Session rescheduled", "source": "Either", "target": "Both"},
    {"key": "session.cancelled", "display": "Session", "trigger": "Session cancelled", "source": "Either", "target": "Both"},
    {"key": "session.reminder", "display": "Session", "trigger": "15 min before session", "source": "System", "target": "Both"},
    {"key": "message.received", "display": "Message", "trigger": "New message sent", "source": "User", "target": "Recipient"},
    {"key": "resource.shared", "display": "Resource", "trigger": "Resource shared", "source": "Mentor", "target": "Student"},
    {"key": "event.registered", "display": "Event", "trigger": "Event registration", "source": "Student", "target": "Mentor"},
    {"key": "review.submitted", "display": "Review", "trigger": "Review submitted", "source": "Student", "target": "Mentor"},
    {"key": "journal.created", "display": "Journal", "trigger": "Journal entry created", "source": "Student", "target": "Mentor"}
  ],
  "functionalTests": [
    {"id": "FUNC-01", "name": "Notification creation", "description": "Record inserted into notifications table upon trigger"},
    {"id": "FUNC-02", "name": "Content correctness", "description": "Title, body, metadata, type are accurate"},
    {"id": "FUNC-03", "name": "Targeting", "description": "Notification assigned to correct recipient"},
    {"id": "FUNC-04", "name": "Badge increment", "description": "user_badge_counts.unread_count increments by 1"},
    {"id": "FUNC-05", "name": "Mark single as read", "description": "PATCH updates read_at; badge decrements"},
    {"id": "FUNC-06", "name": "Mark all as read", "description": "All unread marked read; badge resets to 0"},
    {"id": "FUNC-07", "name": "Delete single", "description": "Soft/hard deleted; badge adjusted"},
    {"id": "FUNC-08", "name": "Clear all", "description": "All removed; badge reset"},
    {"id": "FUNC-09", "name": "Notification list", "description": "Paginated list sorted by created_at DESC"},
    {"id": "FUNC-10", "name": "Read/unread filter", "description": "Filter param returns correct subset"},
    {"id": "FUNC-11", "name": "Pagination", "description": "limit and offset params work correctly"},
    {"id": "FUNC-12", "name": "Empty state", "description": "Empty array when no notifications"},
    {"id": "FUNC-13", "name": "Type filtering", "description": "Filtered by type returns correct subset"},
    {"id": "FUNC-14", "name": "Click action", "description": "action_url navigates to correct screen"},
    {"id": "FUNC-15", "name": "Preference opt-out", "description": "Disabled type → no notification created"},
    {"id": "FUNC-16", "name": "Preference opt-in", "description": "Re-enabled type → notifications created"}
  ],
  "realtimeTests": [
    {"id": "RT-01", "name": "Realtime delivery within SLA", "assertion": "Notification received within 2s of trigger"},
    {"id": "RT-02", "name": "Subscription resumption on reconnect", "assertion": "Missed events delivered after reconnect"},
    {"id": "RT-03", "name": "Multiple tab delivery", "assertion": "All open tabs receive event simultaneously"},
    {"id": "RT-04", "name": "Event ordering", "assertion": "Sequential mutations delivered in order"},
    {"id": "RT-05", "name": "Payload correctness", "assertion": "INSERT/UPDATE/DELETE payloads contain correct fields"},
    {"id": "RT-06", "name": "Concurrent subscriptions", "assertion": "Multiple channels managed without interference"},
    {"id": "RT-07", "name": "Badge realtime update", "assertion": "Badge count updates without page refresh"},
    {"id": "RT-08", "name": "Network interruption", "assertion": "Reconnection with backoff, no duplicate events"},
    {"id": "RT-09", "name": "Server restart", "assertion": "Subscription resumes, missed events recovered"},
    {"id": "RT-10", "name": "Rapid state changes", "assertion": "10 rapid mutations: all delivered, no drop"},
    {"id": "RT-11", "name": "Large payload", "assertion": "Notification with 10KB metadata delivered correctly"},
    {"id": "RT-12", "name": "Channel cleanup", "assertion": "Unsubscribe removes channel, no memory leak"}
  ],
  "negativeTests": [
    {"id": "NEG-01", "scenario": "Create notification for non-existent user", "expected": "FK violation or graceful rejection"},
    {"id": "NEG-02", "scenario": "Mark already-read notification as read", "expected": "No-op, read_at unchanged"},
    {"id": "NEG-03", "scenario": "Delete notification from another user", "expected": "RLS prevents, 0 rows affected"},
    {"id": "NEG-04", "scenario": "Subscribe with invalid JWT", "expected": "Realtime subscription rejected"},
    {"id": "NEG-05", "scenario": "Exceed badge count max (999+)", "expected": "Cap at max or correct overflow"},
    {"id": "NEG-06", "scenario": "Empty notification preference payload", "expected": "Defaults applied"},
    {"id": "NEG-07", "scenario": "Concurrent mark-read from 2 tabs", "expected": "No race condition, badge correct"},
    {"id": "NEG-08", "scenario": "Notification with null action_url", "expected": "Renders without link, no crash"},
    {"id": "NEG-09", "scenario": "10K+ notifications in list", "expected": "Pagination preserves performance"},
    {"id": "NEG-10", "scenario": "Special characters in notification body", "expected": "Sanitized display, no XSS"},
    {"id": "NEG-11", "scenario": "Realtime channel spoofing", "expected": "Auth prevents cross-user channel access"},
    {"id": "NEG-12", "scenario": "Queue full (backpressure)", "expected": "Graceful degradation, no crash"}
  ]
}
