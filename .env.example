# =============================================================================
# Required — Supabase
# =============================================================================
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# =============================================================================
# Required — Environment
# =============================================================================
# Values: development | staging | production
VITE_APP_ENV=development

# =============================================================================
# Edge Functions (local dev)
# =============================================================================
# Set to http://localhost:54321 for local Supabase instance
VITE_SUPABASE_FUNCTIONS_URL=

# =============================================================================
# Admin Operations (seeding, local dev only)
# =============================================================================
# Only used in scripts/seedAuthUsers.ts — never set in production
SUPABASE_SERVICE_ROLE_KEY=

# =============================================================================
# Edge Function Secrets (set via supabase secrets set, not .env)
# Required by: supabase/functions/resend/index.ts, supabase/functions/gemini/index.ts
# =============================================================================
SUPABASE_URL=
RESEND_API_KEY=
GEMINI_API_KEY=
CRON_SECRET=

# =============================================================================
# Feature Flags
# =============================================================================
# Route application approval through secure edge function (enable in prod)
VITE_ENABLE_EDGE_APPROVAL=false

# State machine with idempotency/retry/rollback (requires EDGE_APPROVAL=true)
VITE_ENABLE_TRANSACTIONAL_PROVISIONING=false

# =============================================================================
# Optional — Monitoring
# =============================================================================
VITE_SENTRY_DSN=your_sentry_dsn
VITE_POSTHOG_API_KEY=
VITE_POSTHOG_HOST=

# =============================================================================
# E2E / QA — Staging Test Users (set in .env.local or CI secrets)
# =============================================================================
STAGING_MENTOR_EMAIL=mentor.qa@mentorino.test
STAGING_MENTOR_PASSWORD=
STAGING_STUDENT1_EMAIL=student1.qa@mentorino.test
STAGING_STUDENT1_PASSWORD=
STAGING_STUDENT2_EMAIL=student2.qa@mentorino.test
STAGING_STUDENT2_PASSWORD=
STAGING_PASSWORD=
STAGING_DATABASE_URL=
BASE_URL=http://localhost:3000


